# Environment variables

# Set to 'development' for development environment
NODE_ENV=production

# Used in status endpoint and for logging, set to your name or team name
DEPLOYED_BY=bcsaldias

# Server port
PORT=3000

# Database connection settings
PGHOST=your-db-host
PGPORT=your-db-port

# Session secret
SESSION_SECRET=your-session-secret

# Allow superuser mode, used only for demo purposes (set to true to enable, but be cautious!)
ALLOW_SUPERUSER_MODE=false

# Schema sanity-check gate:
# 1 skips milestone 2+ checks,
# 2 requires users/channels/channel_members,
# 3 also requires the messages table and its user/channel foreign keys
SANITY_CHECK_MILESTONE=2

# Demo-only pool size (demo db user)
PG_POOL_MAX=40
PG_POOL_MAX_DEFAULT=3
PG_POOL_IDLE_MS=15000
PG_POOL_CONN_MS=3000

# Demo credentials (set to enable /api/demo/login)
DEMO_DB_USER=demo
REAL_DEMO_PASSWORD=really_secure_demo_password
HEALTHCHECK_DB_USER=demo
HEALTHCHECK_DB_PASS=really_secure_demo_password

# Instructor progress (set to enable /api/instructor/progress)
INSTRUCTOR_TOKEN=super_secure_instructor_token

# SQL submissions / progress log paths (optional overrides)
SQL_SUBMISSIONS_DIR=./submissions
SQL_PROGRESS_LOG=./submissions/progress_log.jsonl

# Comma-separated list of database users to exclude from instructor progress tracking
# use to exclude TAs testing with their own accounts, for example
INSTRUCTOR_EXCLUDED_DB_USERS=grp15_ba,grp27_bb,grp45_ca,grp60_cb
